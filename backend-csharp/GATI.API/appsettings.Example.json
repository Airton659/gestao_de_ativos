{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Driver={FreeTDS};Server=YOUR_DB_SERVER;Port=YOUR_DB_PORT;Database=YOUR_DB_NAME;UID=YOUR_DB_USER;PWD=YOUR_DB_PASSWORD;TDS_Version=7.4;"
  },
  "Jwt": {
    "SecretKey": "YOUR_JWT_SECRET_AT_LEAST_32_CHARACTERS_LONG",
    "ExpireMinutes": 240
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "User": "your@email.com",
    "Password": "YOUR_SMTP_PASSWORD",
    "FromName": "Gestão de Ativos de TI",
    "From": "your@email.com"
  }
}
